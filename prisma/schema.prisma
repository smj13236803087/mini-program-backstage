// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id               String   @id @default(cuid())
  email            String   @unique
  password         String   // 存储加密后的密码
  name             String?
  shopifyCustomerId String? @unique // Shopify 客户 ID，用于同步
  shopifyEmail    String?  // Shopify 客户邮箱（用于匹配）
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // 关联：用户的手串作品集
  braceletDesigns  BraceletDesign[]

  // 关联：用户的收货地址（我的地址）
  addresses        Address[]
  defaultAddressId String?  @unique
  defaultAddress   Address? @relation("DefaultAddress", fields: [defaultAddressId], references: [id])

  @@map("users")
}

model PendingUser {
  email            String   @id
  name             String
  password         String
  verificationCode String
  expiresAt        DateTime
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("pending_users")
}

model BraceletDesign {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  name            String   // 作品名称
  totalPrice      Float    // 总价格
  totalWeight     Float?   // 总重量（克）
  averageDiameter Float?   // 平均直径（毫米）
  wristSize       Float?   // 设计时的手围（厘米）
  wearingStyle    String?  // single / double
  items           Json     // BraceletItem[]，包含顺序和位置
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@map("bracelet_designs")
}

/// 收货地址（一个用户可以有多个地址）
model Address {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])

  // 收件人信息
  recipient   String   // 收件人姓名
  phone       String   // 手机号

  // 详细地址信息
  country     String   @default("中国")
  province    String
  city        String
  district    String
  detail      String   // 详细街道门牌
  postalCode  String?  // 邮编

  // 辅助信息
  tag         String?  // 家/公司/学校 等标签

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // 反向关联：如果这个地址被设为用户默认地址
  defaultForUser User? @relation("DefaultAddress")

  @@index([userId])
  @@map("addresses")
}
