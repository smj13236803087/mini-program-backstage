// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Product {
  id String @id @default(cuid())
  title String
  productType String
  imageUrl String?
  images Json?
  price Decimal @db.Decimal(10, 2) // 基础单价（元），对应 variants[0].price
  stock Int @default(0)            // 真实库存
  energy_tags Json?                // 能量标签（用于 AI 匹配），如 ["情绪","智慧"]
  diameter String?
  weight String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id             String    @id @default(cuid())
  weixin_openid  String?   @unique
  email          String?   @unique
  password       String?
  role           Role      @default(USER)
  avatar         String?
  gender         Int?
  nickname       String?
  birthday       DateTime?
  signature      String?                   // 个性签名
  phone          String?
  phone_verified Boolean   @default(false) // 手机号是否已验证（微信获取）
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  braceletDesigns BraceletDesign[]         // 关联：用户的手串作品集
  addresses        Address[]
  defaultAddressId String?   @unique
  defaultAddress   Address?  @relation("DefaultAddress", fields: [defaultAddressId], references: [id])
  carts Cart[]
  orders Order[]

  @@map("users")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  USER
}

model PendingUser {
  email            String   @id
  name             String
  password         String
  verificationCode String
  expiresAt        DateTime
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("pending_users")
}

model BraceletDesign {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  totalPrice      Float
  totalWeight     Float?
  averageDiameter Float?
  wristSize       Float?  // 设计时的手围（厘米）
  wearingStyle    String? // single / double
  items           Json    // BraceletItem[]，包含顺序和位置
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@map("bracelet_designs")
}

/// 收货地址（一个用户可以有多个地址）
model Address {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])
  recipient String
  phone     String
  country    String  @default("中国")
  province   String
  city       String
  district   String
  detail     String 
  tag String?                                      // 家/公司/学校 等标签
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  defaultForUser User? @relation("DefaultAddress") // 反向关联：如果这个地址被设为用户默认地址

  @@index([userId])
  @@map("addresses")
}

/// 购物车（一个用户可以有一个或多个购物车记录，这里简单设计为一个用户一个活跃购物车）
model Cart {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  items CartItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

/// 购物车条目：保存手串设计的快照
model CartItem {
  id String @id @default(cuid())

  cartId String
  cart   Cart   @relation(fields: [cartId], references: [id])

  /// 该设计在购物车中的名称（通常来自 designName）
  name String?

  /// 手串设计快照：包含 items、wristSize、wearingStyle、totalPrice 等
  design Json

  /// 设计总价（元）
  totalPrice Float

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([cartId])
}

/// 订单主表
model Order {
  id String @id @default(cuid())
  userId String // 下单用户
  user   User   @relation(fields: [userId], references: [id])
  status String @default("pending") // 订单状态：pending / to_pay / to_ship / to_receive / done / cancelled / refund
  totalAmount Decimal @db.Decimal(10, 2)  // 订单商品总金额（含运费前）
  payAmount Decimal @db.Decimal(10, 2) // 实际支付金额（可含运费/优惠后）
  freightAmount Decimal @db.Decimal(10, 2) @default(0.0) // 运费金额
  remark String? // 用户备注

  /// 实物检视阶段上传的实拍图（1-3 张 URL）
  inspectImages Json?

  /// 收件人快照（下单时写死，避免地址后改动）
  recipient String
  phone     String
  country   String  @default("中国")
  province  String
  city      String
  district  String
  detail    String
  postalCode String?

  designSnapshot Json?  // 关联的设计/商品（可选）

  /// 支付相关
  outTradeNo  String? @unique
  payStatus   String  @default("unpaid") // unpaid / paid / refunded
  payChannel  String? // wechat 等
  paidAt      DateTime?

  /// 物流相关
  shippingCompany String?
  trackingNo      String?
  shippedAt       DateTime?
  receivedAt      DateTime?

  /// 退款相关
  refundStatus String? // requested / processing / done / rejected
  refundAmount Decimal? @db.Decimal(10, 2)
  refundReason String?
  refundedAt   DateTime?

  items OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("orders")
}

/// 订单明细表
model OrderItem {
  id String @id @default(cuid())

  orderId String
  order   Order @relation(fields: [orderId], references: [id])

  /// 商品/设计标识（可选）
  productId       String?
  braceletDesignId String?

  /// 展示名称
  name String

  /// 单价与数量
  unitPrice Decimal @db.Decimal(10, 2)
  quantity  Int
  subtotal  Decimal @db.Decimal(10, 2)

  /// 设计/商品完整快照
  snapshot Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orderId])
  @@map("order_items")
}

