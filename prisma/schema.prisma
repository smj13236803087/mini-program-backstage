// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

/// 商品图鉴（按“物料名称”聚合的展示信息）
model ProductAtlas {
  id String @id @default(cuid())

  /// 物料名称（图鉴主标题）
  title String
  imageUrl String?
  /// 大分类（用于图鉴展示/筛选；商品 SKU 通过关联图鉴继承展示）
  majorCategory String?
  /// 色系 / 色系归属（支持 #RRGGBB 或文字）
  colorSeries String?

  /// 核心能量标签
  coreEnergyTag String? @db.Text
  /// 矿脉溯源
  mineVeinTrace String? @db.Text
  /// 材质溯源
  materialTrace String? @db.Text
  /// 视觉特征
  visualFeatures String? @db.Text
  /// 经典六维（JSON 或长文本）
  classicSixDimensions String? @db.Text
  /// 生肖
  zodiac String?
  /// 五行
  fiveElements String?
  /// 星座
  constellation String?
  /// 脉轮
  chakra String?

  products Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([title])
  @@index([majorCategory])
  @@unique([title, majorCategory])
  @@map("product_atlas")
}

/// 商品 SKU（同一物料名称可有多种粒径/规格；此表只存价格/规格等可变信息）
model Product {
  id String @id @default(cuid())

  /// 物料编号（Excel 导入；工作台珠子稳定 id 优先用此字段）
  materialCode String? @unique

  atlasId String?
  atlas   ProductAtlas? @relation(fields: [atlasId], references: [id], onDelete: SetNull)

  price Decimal @db.Decimal(10, 2) // 基础单价（元）
  diameter String?
  weight String?

  inventory Inventory?
  /// 库存变动流水（一个商品多条）
  inventoryLogs InventoryLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([atlasId])
  @@index([diameter])
}

model Inventory {
  id String @id @default(cuid())

  productId String @unique
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  /// 当前库存
  quantity Int @default(0)

  updatedAt DateTime @updatedAt
}



model InventoryLog {
  id String @id @default(cuid())

  productId String
  product Product @relation(fields: [productId], references: [id])

  /// 变动类型：入库 / 销售 / 调整
  type InventoryLogType

  /// 本次变动数量（正负根据类型）
  quantity Int

  /// 变动前库存
  beforeQty Int

  /// 变动后库存
  afterQty Int

  /// 备注，可写“用户支付成功”、“人工盘点”等
  remark String?

  createdAt DateTime @default(now())
}

enum InventoryLogType {
  PURCHASE   // 入库
  SALE       // 销售
  ADJUST     // 人工调整
}


model User {
  id             String    @id @default(cuid())
  weixin_openid  String?   @unique
  email          String?   @unique
  password       String?
  role           Role      @default(USER)
  avatar         String?
  gender         Int?
  nickname       String?
  birthday       DateTime?
  signature      String?                   // 个性签名
  phone          String?
  phone_verified Boolean   @default(false) // 手机号是否已验证（微信获取）
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  braceletDesigns BraceletDesign[]         // 关联：用户的手串作品集
  addresses        Address[]
  defaultAddressId String?   @unique
  defaultAddress   Address?  @relation("DefaultAddress", fields: [defaultAddressId], references: [id])
  carts Cart[]
  orders Order[]
  plazaPosts PlazaPost[]

  @@map("users")
}

/// 灵感广场：用户开启「共创分享」后发布的配方快照（一条作品对应一条广场记录，重复发布则更新）
model PlazaPost {
  id               String   @id @default(cuid())
  braceletDesignId String   @unique
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// 发布时的完整设计快照（含 items、手围、总价等），珠子已富化 imageUrl
  snapshot         Json
  /// 用户命名（广场标题优先；与 snapshot.title 同步写入）
  recipeName       String?  @db.VarChar(120)
  /// 配方理念 / 创作说明
  recipePhilosophy String?  @db.Text
  /// 标签 string[] JSON，仅允许预设标签
  recipeTags       Json?
  adoptCount       Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([userId])
  @@map("plaza_posts")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  USER
}

model PendingUser {
  email            String   @id
  name             String
  password         String
  verificationCode String
  expiresAt        DateTime
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("pending_users")
}

model BraceletDesign {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  totalPrice      Float
  totalWeight     Float?
  averageDiameter Float?
  wristSize       Float?  // 设计时的手围（厘米）
  wearingStyle    String? // single / double
  items           Json    // BraceletItem[]，包含顺序和位置
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@map("bracelet_designs")
}

/// 收货地址（一个用户可以有多个地址）
model Address {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])
  recipient String
  phone     String
  country    String  @default("中国")
  province   String
  city       String
  district   String
  detail     String 
  tag String?                                      // 家/公司/学校 等标签
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  defaultForUser User? @relation("DefaultAddress") // 反向关联：如果这个地址被设为用户默认地址

  @@index([userId])
  @@map("addresses")
}

/// 购物车（一个用户可以有一个或多个购物车记录，这里简单设计为一个用户一个活跃购物车）
model Cart {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  items CartItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

/// 购物车条目：保存手串设计的快照
model CartItem {
  id String @id @default(cuid())

  cartId String
  cart   Cart   @relation(fields: [cartId], references: [id])

  /// 该设计在购物车中的名称（通常来自 designName）
  name String?

  /// 手串设计快照：包含 items、wristSize、wearingStyle、totalPrice 等
  design Json

  /// 设计总价（元）
  totalPrice Float

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([cartId])
}

/// 订单主表
model Order {
  id String @id @default(cuid())
  userId String // 下单用户
  user   User   @relation(fields: [userId], references: [id])
  status String @default("pending") // 订单状态：pending / to_pay / to_ship / to_receive / done / cancelled / refund
  totalAmount Decimal @db.Decimal(10, 2)  // 订单商品总金额（含运费前）
  payAmount Decimal @db.Decimal(10, 2) // 实际支付金额（可含运费/优惠后）
  freightAmount Decimal @db.Decimal(10, 2) @default(0.0) // 运费金额
  remark String? // 用户备注

  /// 实物检视阶段上传的实拍图（1-3 张 URL）
  inspectImages Json?

  /// 收件人快照（下单时写死，避免地址后改动）
  recipient String
  phone     String
  country   String  @default("中国")
  province  String
  city      String
  district  String
  detail    String
  postalCode String?

  designSnapshot Json?  // 关联的设计/商品（可选）

  /// 支付相关
  outTradeNo  String? @unique
  payStatus   String  @default("unpaid") // unpaid / paid / refunded
  payChannel  String? // wechat 等
  paidAt      DateTime?

  /// 销售出库已完成（扣库存 + 写 SALE 流水），用于幂等
  stockDeductedAt DateTime?

  /// 物流相关
  shippingCompany String?
  trackingNo      String?
  shippedAt       DateTime?
  receivedAt      DateTime?

  /// 退款相关
  refundStatus String? // requested / processing / done / rejected
  refundAmount Decimal? @db.Decimal(10, 2)
  refundReason String?
  refundedAt   DateTime?

  items OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("orders")
}

/// 订单明细表
model OrderItem {
  id String @id @default(cuid())

  orderId String
  order   Order @relation(fields: [orderId], references: [id])

  /// 商品/设计标识（可选）
  productId       String?
  braceletDesignId String?

  /// 展示名称
  name String

  /// 单价与数量
  unitPrice Decimal @db.Decimal(10, 2)
  quantity  Int
  subtotal  Decimal @db.Decimal(10, 2)

  /// 设计/商品完整快照
  snapshot Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orderId])
  @@map("order_items")
}

