// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

/// 小程序 / 后台商品表（取代 Shopify 商品作为小程序商品来源）
model Product {
  id String @id @default(cuid())

  /// 商品名称（原 Shopify 的 title）
  title String

  /// 商品类型，对应 Shopify 的 product_type（用于 categorizeProducts）
  productType String

  /// 主图地址
  imageUrl String?

  /// 轮播图等图片列表（JSON 数组，元素对象需包含 src 字段）
  images Json?

  /// 基础单价（元），对应 variants[0].price
  price Decimal @db.Decimal(10, 2)

  /// 直径选项，例如 "8mm"（用于 options: name=diameter）
  diameter String?

  /// 重量选项，例如 "1.65g"（用于 options: name=weight）
  weight String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id             String    @id @default(cuid())
  weixin_openid  String?   @unique // 微信 openid
  avatar         String? // 头像
  gender         Int? // 性别 0：未知、1：男、2：女
  nickname       String? // 昵称
  birthday       DateTime? // 生日
  signature      String? // 个性签名（最多100字）
  phone          String? // 手机号
  phone_verified Boolean   @default(false) // 手机号是否已验证（微信获取）
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // 关联：用户的手串作品集
  braceletDesigns BraceletDesign[]

  // 关联：用户的收货地址（我的地址）
  addresses        Address[]
  defaultAddressId String?   @unique
  defaultAddress   Address?  @relation("DefaultAddress", fields: [defaultAddressId], references: [id])

  // 关联：用户的购物车
  carts Cart[]

  @@map("users")
}

model PendingUser {
  email            String   @id
  name             String
  password         String
  verificationCode String
  expiresAt        DateTime
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("pending_users")
}

model BraceletDesign {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  totalPrice      Float // 总价格
  totalWeight     Float? // 总重量（克）
  averageDiameter Float? // 平均直径（毫米）
  wristSize       Float? // 设计时的手围（厘米）
  wearingStyle    String? // single / double
  items           Json // BraceletItem[]，包含顺序和位置
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@map("bracelet_designs")
}

/// 收货地址（一个用户可以有多个地址）
model Address {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  // 收件人信息
  recipient String // 收件人姓名
  phone     String // 手机号

  // 详细地址信息
  country    String  @default("中国")
  province   String
  city       String
  district   String
  detail     String // 详细街道门牌
  postalCode String? // 邮编

  // 辅助信息
  tag String? // 家/公司/学校 等标签

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 反向关联：如果这个地址被设为用户默认地址
  defaultForUser User? @relation("DefaultAddress")

  @@index([userId])
  @@map("addresses")
}

/// 购物车（一个用户可以有一个或多个购物车记录，这里简单设计为一个用户一个活跃购物车）
model Cart {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  items CartItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

/// 购物车条目：保存手串设计的快照
model CartItem {
  id String @id @default(cuid())

  cartId String
  cart   Cart   @relation(fields: [cartId], references: [id])

  /// 该设计在购物车中的名称（通常来自 designName）
  name String?

  /// 手串设计快照：包含 items、wristSize、wearingStyle、totalPrice 等
  design Json

  /// 设计总价（元）
  totalPrice Float

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([cartId])
}
